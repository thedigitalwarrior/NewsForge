---
import BaseLayout from "@shared/layouts/BaseLayout.astro";
import Search from "@shared/components/Search.astro";
import { site } from "../config/site";
---

<BaseLayout
  site={site}
  title="Cerca"
  description="Cerca tra gli articoli di TabletNexus."
>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="mb-6 text-3xl font-extrabold tracking-tight text-gray-900">Cerca</h1>
    <Search />
    <noscript>
      <p class="text-gray-600">La ricerca richiede JavaScript attivo.</p>
    </noscript>
  </div>
</BaseLayout>
