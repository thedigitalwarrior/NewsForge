---
import type { GetStaticPaths } from "astro";
import BaseLayout from "@shared/layouts/BaseLayout.astro";
import Search from "@shared/components/Search.astro";
import { locales, type Locale } from "@shared/i18n/config";
import { searchUrl } from "@shared/i18n/routes";
import { useTranslations } from "@shared/i18n/ui";
import { site } from "../../config/site";

export const getStaticPaths = (async () => {
  return locales.map((lang) => ({ params: { lang } }));
}) satisfies GetStaticPaths;

const lang = Astro.params.lang as Locale;
const t = useTranslations(lang);

const alternates: Partial<Record<Locale, string>> = {};
for (const l of locales) alternates[l] = searchUrl(l);
---

<BaseLayout
  site={site}
  lang={lang}
  title={t("search.title")}
  alternates={alternates}
>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="mb-6 text-3xl font-extrabold tracking-tight text-gray-900">
      {t("search.title")}
    </h1>
    <Search lang={lang} />
    <noscript>
      <p class="text-gray-600">{t("search.noscript")}</p>
    </noscript>
  </div>
</BaseLayout>
