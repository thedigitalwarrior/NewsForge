---
import type { GetStaticPaths } from "astro";
import BaseLayout from "@shared/layouts/BaseLayout.astro";
import ArticleCard from "@shared/components/ArticleCard.astro";
import { getVisibleNews } from "@shared/lib/news";
import { slugify } from "@shared/lib/utils";
import { site } from "../../config/site";

export const getStaticPaths = (async () => {
  const posts = await getVisibleNews();
  return site.categories.map((cat) => {
    const items = posts.filter((p) => slugify(p.data.category) === cat.slug);
    return { params: { category: cat.slug }, props: { label: cat.label, items } };
  });
}) satisfies GetStaticPaths;

const { label, items } = Astro.props;
---

<BaseLayout site={site} title={label} description={`Articoli nella categoria ${label}.`}>
  <div class="mx-auto max-w-5xl px-4 py-10">
    <p class="text-sm text-gray-500">Categoria</p>
    <h1 class="mb-8 text-3xl font-extrabold tracking-tight text-gray-900">{label}</h1>
    {
      items.length > 0 ? (
        <section class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {items.map((post) => (
            <ArticleCard post={post} />
          ))}
        </section>
      ) : (
        <p class="text-gray-600">Nessun articolo in questa categoria, per ora.</p>
      )
    }
  </div>
</BaseLayout>
