---
import type { SiteConfig } from "../config/site";
import type { Locale } from "../i18n/config";
import { aboutUrl } from "../i18n/routes";
import { useTranslations } from "../i18n/ui";

interface Props {
  site: SiteConfig;
  lang: Locale;
}

const { site, lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-gray-200 bg-gray-50">
  <div
    class="mx-auto flex max-w-5xl flex-col gap-2 px-4 py-8 text-sm text-gray-500 sm:flex-row sm:items-center sm:justify-between"
  >
    <p>© {year} {site.name} · {site.domain}</p>
    <p class="text-xs">
      {t("footer.aiNotice")}{" "}
      <a href={aboutUrl(lang)} class="text-brand-dark hover:underline">
        {t("footer.aiLink")}</a
      >.
    </p>
  </div>
</footer>
