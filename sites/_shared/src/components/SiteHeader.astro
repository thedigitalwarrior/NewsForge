---
import type { SiteConfig } from "../config/site";
import type { Locale } from "../i18n/config";
import { categoryUrl, homeUrl, searchUrl } from "../i18n/routes";
import { useTranslations } from "../i18n/ui";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  site: SiteConfig;
  lang: Locale;
  alternates: Partial<Record<Locale, string>>;
}

const { site, lang, alternates } = Astro.props;
const t = useTranslations(lang);
---

<header class="sticky top-0 z-20 border-b border-gray-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3">
    <a href={homeUrl(lang)} class="flex flex-col leading-tight">
      <span class="text-xl font-extrabold tracking-tight text-gray-900">
        {site.name}
      </span>
      <span class="text-xs text-gray-500">{site.tagline[lang]}</span>
    </a>
    <div class="flex items-center gap-1">
      <nav class="hidden gap-1 sm:flex">
        {
          site.categories.map((cat) => (
            <a
              href={categoryUrl(lang, cat.key)}
              class="rounded-md px-3 py-1.5 text-sm font-medium text-gray-600 transition hover:bg-brand/10 hover:text-brand-dark"
            >
              {cat.labels[lang]}
            </a>
          ))
        }
      </nav>
      <a
        href={searchUrl(lang)}
        aria-label={t("nav.search")}
        class="rounded-md p-2 text-gray-600 transition hover:bg-brand/10 hover:text-brand-dark"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-5 w-5"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>
      <span class="mx-1 hidden h-5 w-px bg-gray-200 sm:block"></span>
      <LanguageSwitcher lang={lang} alternates={alternates} />
    </div>
  </div>
</header>
