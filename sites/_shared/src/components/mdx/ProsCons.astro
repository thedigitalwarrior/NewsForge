---
/**
 * Pros / cons box. Usage in MDX:
 *   <ProsCons
 *     pro={["Autonomia ottima", "Display luminoso"]}
 *     contro={["Prezzo alto", "Niente jack"]}
 *   />
 */
interface Props {
  pro: string[];
  contro: string[];
}

const { pro, contro } = Astro.props;
---

<div class="not-prose my-8 grid gap-4 sm:grid-cols-2">
  <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-5">
    <h3 class="mb-3 flex items-center gap-2 font-semibold text-emerald-800">
      <span aria-hidden="true">▲</span> Pro
    </h3>
    <ul class="space-y-2 text-sm text-emerald-900">
      {
        pro.map((item) => (
          <li class="flex gap-2">
            <span aria-hidden="true" class="text-emerald-600">
              +
            </span>
            <span>{item}</span>
          </li>
        ))
      }
    </ul>
  </div>
  <div class="rounded-xl border border-rose-200 bg-rose-50 p-5">
    <h3 class="mb-3 flex items-center gap-2 font-semibold text-rose-800">
      <span aria-hidden="true">▼</span> Contro
    </h3>
    <ul class="space-y-2 text-sm text-rose-900">
      {
        contro.map((item) => (
          <li class="flex gap-2">
            <span aria-hidden="true" class="text-rose-600">
              −
            </span>
            <span>{item}</span>
          </li>
        ))
      }
    </ul>
  </div>
</div>
