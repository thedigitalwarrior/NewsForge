---
import { locales, localeNames, type Locale } from "../i18n/config";

interface Props {
  lang: Locale;
  /** URL of the equivalent page per locale (missing = no translation). */
  alternates: Partial<Record<Locale, string>>;
}

const { lang, alternates } = Astro.props;
---

<details class="lang-switcher relative">
  <summary
    class="flex cursor-pointer list-none items-center gap-1.5 rounded-md px-2 py-1.5 text-sm font-medium text-gray-600 transition hover:bg-brand/10 hover:text-brand-dark"
    aria-label="Language"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="h-4 w-4"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M2 12h20"></path>
      <path d="M12 2a15.3 15.3 0 0 1 0 20 15.3 15.3 0 0 1 0-20z"></path>
    </svg>
    <span>{lang.toUpperCase()}</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="chevron h-3.5 w-3.5 transition-transform"
      aria-hidden="true"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </summary>

  <ul
    class="absolute right-0 z-30 mt-2 max-h-64 min-w-[10rem] overflow-y-auto rounded-lg border border-gray-200 bg-white py-1 shadow-lg"
  >
    {
      locales.map((l) => {
        const url = alternates[l];
        const current = l === lang;
        if (current) {
          return (
            <li>
              <span
                aria-current="true"
                class="flex items-center justify-between bg-brand/5 px-4 py-2 text-sm font-semibold text-brand-dark"
              >
                {localeNames[l]}
                <span aria-hidden="true">✓</span>
              </span>
            </li>
          );
        }
        return (
          <li>
            {url ? (
              <a
                href={url}
                class="block px-4 py-2 text-sm text-gray-700 transition hover:bg-brand/10 hover:text-brand-dark"
              >
                {localeNames[l]}
              </a>
            ) : (
              <span
                class="block px-4 py-2 text-sm text-gray-300"
                title="Not available in this language"
              >
                {localeNames[l]}
              </span>
            )}
          </li>
        );
      })
    }
  </ul>
</details>

<style>
  /* Hide the native disclosure marker; we render our own chevron. */
  .lang-switcher > summary {
    list-style: none;
  }
  .lang-switcher > summary::-webkit-details-marker {
    display: none;
  }
  .lang-switcher[open] .chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  // Explicit island: close the language menu on outside click or Escape.
  const closeAll = (except?: Element) => {
    document.querySelectorAll("details.lang-switcher[open]").forEach((d) => {
      if (d !== except) d.removeAttribute("open");
    });
  };
  document.addEventListener("click", (e) => {
    const open = (e.target as Element)?.closest?.("details.lang-switcher");
    closeAll(open ?? undefined);
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeAll();
  });
</script>
