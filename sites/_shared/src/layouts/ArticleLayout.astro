---
import { render, type CollectionEntry } from "astro:content";
import { categoryLabel, type SiteConfig } from "../config/site";
import { locales, type Locale } from "../i18n/config";
import { articleUrl } from "../i18n/routes";
import { useTranslations } from "../i18n/ui";
import { getNewsTranslations, parseNewsId } from "../lib/news";
import BaseLayout from "./BaseLayout.astro";
import CategoryBadge from "../components/CategoryBadge.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { mdxComponents } from "../components/mdx";

interface Props {
  site: SiteConfig;
  lang: Locale;
  post: CollectionEntry<"news">;
}

const { site, lang, post } = Astro.props;
const { slug } = parseNewsId(post.id);
const { title, description, pubDate, category, image, imageAlt, sources } =
  post.data;
const { Content } = await render(post);
const t = useTranslations(lang);
const label = categoryLabel(site, category, lang);

// Alternates: the locales that actually have this slug translated.
const available = await getNewsTranslations(slug);
const alternates: Partial<Record<Locale, string>> = {};
for (const l of locales) {
  if (available.includes(l)) alternates[l] = articleUrl(l, slug);
}

const ogImage = image ? new URL(image, Astro.site).href : undefined;
---

<BaseLayout
  site={site}
  lang={lang}
  title={title}
  description={description}
  image={ogImage}
  ogType="article"
  alternates={alternates}
>
  <article class="mx-auto max-w-3xl px-4 py-10" data-pagefind-body>
    <header class="mb-8">
      <div class="mb-4 flex items-center gap-3 text-sm text-gray-500">
        <CategoryBadge lang={lang} categoryKey={category} label={label} />
        <FormattedDate date={pubDate} lang={lang} style="long" />
      </div>
      <h1 class="text-4xl font-extrabold leading-tight tracking-tight text-gray-900">
        {title}
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-gray-600">{description}</p>
    </header>

    {
      image && (
        <img
          src={image}
          alt={imageAlt}
          class="mb-10 aspect-[2/1] w-full rounded-xl object-cover"
        />
      )
    }

    <div class="prose prose-lg prose-gray max-w-none">
      <Content components={mdxComponents} />
    </div>

    {
      sources.length > 0 && (
        <footer class="mt-12 border-t border-gray-200 pt-6">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500">
            {t("article.sources")}
          </h2>
          <ul class="mt-3 space-y-1 text-sm">
            {sources.map((url) => (
              <li>
                <a
                  href={url}
                  rel="nofollow noopener"
                  target="_blank"
                  class="text-brand-dark hover:underline"
                >
                  {url}
                </a>
              </li>
            ))}
          </ul>
        </footer>
      )
    }

    <p class="mt-10">
      <a
        href={`/${lang}/`}
        class="text-sm font-medium text-brand-dark hover:underline"
      >
        {t("article.back")}
      </a>
    </p>
  </article>
</BaseLayout>
